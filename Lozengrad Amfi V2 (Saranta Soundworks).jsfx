mid_pk7400_w = 2 * pi * 7400 / srate;
mid_pk7400_cos = cos(mid_pk7400_w);
mid_pk7400_sin = sin(mid_pk7400_w);
mid_pk7400_A = 10 ^ (1.2 / 40);
mid_pk7400_alpha = mid_pk7400_sin / (2 * 0.75);
mid_pk7400_b0 = 1 + mid_pk7400_alpha * mid_pk7400_A;
mid_pk7400_b1 = -2 * mid_pk7400_cos;
mid_pk7400_b2 = 1 - mid_pk7400_alpha * mid_pk7400_A;
