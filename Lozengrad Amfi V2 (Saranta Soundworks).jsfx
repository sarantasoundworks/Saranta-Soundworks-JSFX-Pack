mid_pk850_x1R=0; mid_pk850_x2R=0; mid_pk850_y1R=0; mid_pk850_y2R=0;

mid_pk1320_x1L=0; mid_pk1320_x2L=0; mid_pk1320_y1L=0; mid_pk1320_y2L=0;
mid_pk1320_x1R=0; mid_pk1320_x2R=0; mid_pk1320_y1R=0; mid_pk1320_y2R=0;

mid_pk7400_x1L=0; mid_pk7400_x2L=0; mid_pk7400_y1L=0; mid_pk7400_y2L=0;
mid_pk7400_x1R=0; mid_pk7400_x2R=0; mid_pk7400_y1R=0; mid_pk7400_y2R=0;

auto_gain_env = 0;
gate_env = 0;
gate_rms = 0;
gate_gain = 1;
gate_hold_rem = 0;
gate_state = 1;
max_lookahead = 512;
lookahead_wp = 0;

// Tone Stack states (3-band passive EQ)
ts_bass_x1L=0; ts_bass_x2L=0; ts_bass_y1L=0; ts_bass_y2L=0;
ts_bass_x1R=0; ts_bass_x2R=0; ts_bass_y1R=0; ts_bass_y2R=0;
ts_mid_x1L=0; ts_mid_x2L=0; ts_mid_y1L=0; ts_mid_y2L=0;
ts_mid_x1R=0; ts_mid_x2R=0; ts_mid_y1R=0; ts_mid_y2R=0;
ts_treb_x1L=0; ts_treb_x2L=0; ts_treb_y1L=0; ts_treb_y2L=0;
ts_treb_x1R=0; ts_treb_x2R=0; ts_treb_y1R=0; ts_treb_y2R=0;

// Presence filter state
pres_x1L=0; pres_x2L=0; pres_y1L=0; pres_y2L=0;
pres_x1R=0; pres_x2R=0; pres_y1R=0; pres_y2R=0;

// Resonance filter state
res_x1L=0; res_x2L=0; res_y1L=0; res_y2L=0;
res_x1R=0; res_x2R=0; res_y1R=0; res_y2R=0;

// Bright Cap state (1-pole HPF)
bc_x1L=0; bc_y1L=0;
bc_x1R=0; bc_y1R=0;

// Sag envelope follower
sag_env = 0;
sag_gain = 1;

// Transient Enhancer states
te_fast = 0;
te_slow = 0;

// Harmonic Exciter states
hex_x1L=0; hex_x2L=0; hex_y1L=0; hex_y2L=0;
hex_x1R=0; hex_x2R=0; hex_y1R=0; hex_y2R=0;

// DC blocker states
dc_x1L=0; dc_y1L=0;
dc_x1R=0; dc_y1R=0;

// Hard mode auto gain
auto_gain = 1;

@slider
gate_enable = slider1;
gate_open_thresh = 10 ^ (slider2 / 20);
gate_close_thresh = gate_open_thresh * 0.501;
gate_env_attack = 1 - exp(-1 / (srate * 0.003));
gate_env_release = 1 - exp(-1 / (srate * 0.05));
gate_gain_attack = 1 - exp(-1 / (srate * 0.006));
gate_gain_release = 1 - exp(-1 / (srate * 0.1));
gate_min_gain = 0.0001;
gate_ratio = 4;
gate_lookahead = floor(0.002 * srate);
input_gain = 10 ^ ((slider3 + 21) / 20);
cab_select = slider13;
drive = 10 ^ (slider5 / 20);
drive_comp = drive > 1 ? 1 / (1 + (drive - 1) * 0.1) : 1;
master_vol = 10 ^ (slider12 / 20);
amp_mode = slider4;

// Tone Stack coefficients (interactive EQ)
bass_val = slider6;
mid_val = slider7;
treb_val = slider8;

ts_bass_w = 2 * pi * 200 / srate;
ts_bass_cos = cos(ts_bass_w);
ts_bass_sin = sin(ts_bass_w);
ts_bass_A = 10 ^ ((bass_val - 5) * 4 / 40);
ts_bass_alpha = ts_bass_sin / (2 * 0.7);
ts_bass_sqrtA = sqrt(ts_bass_A);
ts_bass_b0 = ts_bass_A * ((ts_bass_A + 1) - (ts_bass_A - 1) * ts_bass_cos + 2 * ts_bass_sqrtA * ts_bass_alpha);
ts_bass_b1 = 2 * ts_bass_A * ((ts_bass_A - 1) - (ts_bass_A + 1) * ts_bass_cos);
ts_bass_b2 = ts_bass_A * ((ts_bass_A + 1) - (ts_bass_A - 1) * ts_bass_cos - 2 * ts_bass_sqrtA * ts_bass_alpha);
ts_bass_a0 = (ts_bass_A + 1) + (ts_bass_A - 1) * ts_bass_cos + 2 * ts_bass_sqrtA * ts_bass_alpha;
ts_bass_a1 = -2 * ((ts_bass_A - 1) + (ts_bass_A + 1) * ts_bass_cos);
ts_bass_a2 = (ts_bass_A + 1) + (ts_bass_A - 1) * ts_bass_cos - 2 * ts_bass_sqrtA * ts_bass_alpha;
ts_bass_b0n = ts_bass_b0 / ts_bass_a0;
ts_bass_b1n = ts_bass_b1 / ts_bass_a0;
ts_bass_b2n = ts_bass_b2 / ts_bass_a0;
ts_bass_a1n = ts_bass_a1 / ts_bass_a0;
ts_bass_a2n = ts_bass_a2 / ts_bass_a0;

ts_mid_w = 2 * pi * 800 / srate;
ts_mid_cos = cos(ts_mid_w);
ts_mid_sin = sin(ts_mid_w);
ts_mid_A = 10 ^ ((mid_val - 5) * 4 / 40);
ts_mid_alpha = ts_mid_sin / (2 * 0.8);
ts_mid_b0 = 1 + ts_mid_alpha * ts_mid_A;
ts_mid_b1 = -2 * ts_mid_cos;
ts_mid_b2 = 1 - ts_mid_alpha * ts_mid_A;
ts_mid_a0 = 1 + ts_mid_alpha / ts_mid_A;
ts_mid_a1 = -2 * ts_mid_cos;
ts_mid_a2 = 1 - ts_mid_alpha / ts_mid_A;
ts_mid_b0n = ts_mid_b0 / ts_mid_a0;
ts_mid_b1n = ts_mid_b1 / ts_mid_a0;
ts_mid_b2n = ts_mid_b2 / ts_mid_a0;
ts_mid_a1n = ts_mid_a1 / ts_mid_a0;
ts_mid_a2n = ts_mid_a2 / ts_mid_a0;

ts_treb_w = 2 * pi * 3000 / srate;
ts_treb_cos = cos(ts_treb_w);
ts_treb_sin = sin(ts_treb_w);
ts_treb_A = 10 ^ ((treb_val - 5) * 4 / 40);
ts_treb_alpha = ts_treb_sin / (2 * 0.7);
ts_treb_sqrtA = sqrt(ts_treb_A);
ts_treb_b0 = ts_treb_A * ((ts_treb_A + 1) + (ts_treb_A - 1) * ts_treb_cos + 2 * ts_treb_sqrtA * ts_treb_alpha);
ts_treb_b1 = -2 * ts_treb_A * ((ts_treb_A - 1) + (ts_treb_A + 1) * ts_treb_cos);
ts_treb_b2 = ts_treb_A * ((ts_treb_A + 1) + (ts_treb_A - 1) * ts_treb_cos - 2 * ts_treb_sqrtA * ts_treb_alpha);
ts_treb_a0 = (ts_treb_A + 1) - (ts_treb_A - 1) * ts_treb_cos + 2 * ts_treb_sqrtA * ts_treb_alpha;
ts_treb_a1 = 2 * ((ts_treb_A - 1) - (ts_treb_A + 1) * ts_treb_cos);
ts_treb_a2 = (ts_treb_A + 1) - (ts_treb_A - 1) * ts_treb_cos - 2 * ts_treb_sqrtA * ts_treb_alpha;
ts_treb_b0n = ts_treb_b0 / ts_treb_a0;
ts_treb_b1n = ts_treb_b1 / ts_treb_a0;
ts_treb_b2n = ts_treb_b2 / ts_treb_a0;
ts_treb_a1n = ts_treb_a1 / ts_treb_a0;
ts_treb_a2n = ts_treb_a2 / ts_treb_a0;

// Presence coefficient (high shelf at 4kHz, NFB simulation)
pres_amount = slider10 / 100;
pres_w = 2 * pi * 4000 / srate;
pres_cos = cos(pres_w);
pres_sin = sin(pres_w);
pres_A = 10 ^ (pres_amount * 8 / 40);
pres_alpha = pres_sin / (2 * 0.7);
pres_sqrtA = sqrt(pres_A);
pres_b0 = pres_A * ((pres_A + 1) + (pres_A - 1) * pres_cos + 2 * pres_sqrtA * pres_alpha);
pres_b1 = -2 * pres_A * ((pres_A - 1) + (pres_A + 1) * pres_cos);
pres_b2 = pres_A * ((pres_A + 1) + (pres_A - 1) * pres_cos - 2 * pres_sqrtA * pres_alpha);
pres_a0 = (pres_A + 1) - (pres_A - 1) * pres_cos + 2 * pres_sqrtA * pres_alpha;
pres_a1 = 2 * ((pres_A - 1) - (pres_A + 1) * pres_cos);
pres_a2 = (pres_A + 1) - (pres_A - 1) * pres_cos - 2 * pres_sqrtA * pres_alpha;
pres_b0n = pres_b0 / pres_a0;
pres_b1n = pres_b1 / pres_a0;
pres_b2n = pres_b2 / pres_a0;
pres_a1n = pres_a1 / pres_a0;
pres_a2n = pres_a2 / pres_a0;

// Resonance coefficient (low shelf at 100Hz)
res_amount = slider11 / 100;
res_w = 2 * pi * 100 / srate;
res_cos = cos(res_w);
res_sin = sin(res_w);
res_A = 10 ^ (res_amount * 8 / 40);
res_alpha = res_sin / (2 * 0.9);
res_sqrtA = sqrt(res_A);
res_b0 = res_A * ((res_A + 1) - (res_A - 1) * res_cos + 2 * res_sqrtA * res_alpha);
res_b1 = 2 * res_A * ((res_A - 1) - (res_A + 1) * res_cos);
res_b2 = res_A * ((res_A + 1) - (res_A - 1) * res_cos - 2 * res_sqrtA * res_alpha);
res_a0 = (res_A + 1) + (res_A - 1) * res_cos + 2 * res_sqrtA * res_alpha;
res_a1 = -2 * ((res_A - 1) + (res_A + 1) * res_cos);
res_a2 = (res_A + 1) + (res_A - 1) * res_cos - 2 * res_sqrtA * res_alpha;
res_b0n = res_b0 / res_a0;
res_b1n = res_b1 / res_a0;
res_b2n = res_b2 / res_a0;
res_a1n = res_a1 / res_a0;
res_a2n = res_a2 / res_a0;

// Sag parameters
sag_amount = slider9 / 100;
sag_attack = 1 - exp(-1 / (srate * 0.002));
sag_release = 1 - exp(-1 / (srate * 0.1));

// Bright Cap
bright_cap = slider14;
bc_cutoff = bright_cap == 1 ? 0.0002 : bright_cap == 2 ? 0.0006 : 0;

// Transient Enhancer (attack boost via envelope)
te_amount = slider15 / 100;
te_attack = 1 - exp(-1 / (srate * 0.003));
te_release = 1 - exp(-1 / (srate * 0.05));

// Harmonic Exciter (HPF at 5kHz + soft saturation)
