// Mid EQ coefficients
mid_hpf_w = 2 * pi * 60 / srate;
mid_hpf_cos = cos(mid_hpf_w);
mid_hpf_sin = sin(mid_hpf_w);
mid_hpf_alpha = mid_hpf_sin / (2 * 0.71);
mid_hpf_b0 = (1 + mid_hpf_cos) / 2;
mid_hpf_b1 = -(1 + mid_hpf_cos);
mid_hpf_b2 = (1 + mid_hpf_cos) / 2;
mid_hpf_a0 = 1 + mid_hpf_alpha;
mid_hpf_a1 = -2 * mid_hpf_cos;
mid_hpf_a2 = 1 - mid_hpf_alpha;
mid_hpf_b0n = mid_hpf_b0 / mid_hpf_a0;
mid_hpf_b1n = mid_hpf_b1 / mid_hpf_a0;
mid_hpf_b2n = mid_hpf_b2 / mid_hpf_a0;
mid_hpf_a1n = mid_hpf_a1 / mid_hpf_a0;
mid_hpf_a2n = mid_hpf_a2 / mid_hpf_a0;

mid_ls120_w = 2 * pi * 120 / srate;
mid_ls120_cos = cos(mid_ls120_w);
mid_ls120_sin = sin(mid_ls120_w);
mid_ls120_A = 10 ^ (6.0 / 40);
mid_ls120_alpha = mid_ls120_sin / (2 * 1.3);
mid_ls120_sqrtA = sqrt(mid_ls120_A);
mid_ls120_b0 = mid_ls120_A * ((mid_ls120_A + 1) - (mid_ls120_A - 1) * mid_ls120_cos + 2 * mid_ls120_sqrtA * mid_ls120_alpha);
mid_ls120_b1 = 2 * mid_ls120_A * ((mid_ls120_A - 1) - (mid_ls120_A + 1) * mid_ls120_cos);
mid_ls120_b2 = mid_ls120_A * ((mid_ls120_A + 1) - (mid_ls120_A - 1) * mid_ls120_cos - 2 * mid_ls120_sqrtA * mid_ls120_alpha);
mid_ls120_a0 = (mid_ls120_A + 1) + (mid_ls120_A - 1) * mid_ls120_cos + 2 * mid_ls120_sqrtA * mid_ls120_alpha;
mid_ls120_a1 = -2 * ((mid_ls120_A - 1) + (mid_ls120_A + 1) * mid_ls120_cos);
mid_ls120_a2 = (mid_ls120_A + 1) + (mid_ls120_A - 1) * mid_ls120_cos - 2 * mid_ls120_sqrtA * mid_ls120_alpha;
mid_ls120_b0n = mid_ls120_b0 / mid_ls120_a0;
mid_ls120_b1n = mid_ls120_b1 / mid_ls120_a0;
mid_ls120_b2n = mid_ls120_b2 / mid_ls120_a0;
mid_ls120_a1n = mid_ls120_a1 / mid_ls120_a0;
mid_ls120_a2n = mid_ls120_a2 / mid_ls120_a0;

mid_pk90_w = 2 * pi * 90.5 / srate;
mid_pk90_cos = cos(mid_pk90_w);
mid_pk90_sin = sin(mid_pk90_w);
