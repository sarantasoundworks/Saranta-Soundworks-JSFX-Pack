spl0 = mid_pk1320_b0n * tmp + mid_pk1320_b1n * mid_pk1320_x1L + mid_pk1320_b2n * mid_pk1320_x2L - mid_pk1320_a1n * mid_pk1320_y1L - mid_pk1320_a2n * mid_pk1320_y2L;
mid_pk1320_x2L = mid_pk1320_x1L; mid_pk1320_x1L = tmp; mid_pk1320_y2L = mid_pk1320_y1L; mid_pk1320_y1L = spl0;
tmp = spl1;
spl1 = mid_pk1320_b0n * tmp + mid_pk1320_b1n * mid_pk1320_x1R + mid_pk1320_b2n * mid_pk1320_x2R - mid_pk1320_a1n * mid_pk1320_y1R - mid_pk1320_a2n * mid_pk1320_y2R;
mid_pk1320_x2R = mid_pk1320_x1R; mid_pk1320_x1R = tmp; mid_pk1320_y2R = mid_pk1320_y1R; mid_pk1320_y1R = spl1;

tmp = spl0;
spl0 = mid_pk7400_b0n * tmp + mid_pk7400_b1n * mid_pk7400_x1L + mid_pk7400_b2n * mid_pk7400_x2L - mid_pk7400_a1n * mid_pk7400_y1L - mid_pk7400_a2n * mid_pk7400_y2L;
mid_pk7400_x2L = mid_pk7400_x1L; mid_pk7400_x1L = tmp; mid_pk7400_y2L = mid_pk7400_y1L; mid_pk7400_y1L = spl0;
tmp = spl1;
spl1 = mid_pk7400_b0n * tmp + mid_pk7400_b1n * mid_pk7400_x1R + mid_pk7400_b2n * mid_pk7400_x2R - mid_pk7400_a1n * mid_pk7400_y1R - mid_pk7400_a2n * mid_pk7400_y2R;
mid_pk7400_x2R = mid_pk7400_x1R; mid_pk7400_x1R = tmp; mid_pk7400_y2R = mid_pk7400_y1R; mid_pk7400_y1R = spl1;

spl0 *= 0.7079;
spl1 *= 0.7079;

// Cab
cab_select == 1 ? (
  tmp = spl0;
  spl0 = cab1_hpf_b0n * tmp + cab1_hpf_b1n * cab1_hpf1_x1L + cab1_hpf_b2n * cab1_hpf1_x2L - cab1_hpf_a1n * cab1_hpf1_y1L - cab1_hpf_a2n * cab1_hpf1_y2L;
  cab1_hpf1_x2L = cab1_hpf1_x1L; cab1_hpf1_x1L = tmp; cab1_hpf1_y2L = cab1_hpf1_y1L; cab1_hpf1_y1L = spl0;
  tmp = spl1;
  spl1 = cab1_hpf_b0n * tmp + cab1_hpf_b1n * cab1_hpf1_x1R + cab1_hpf_b2n * cab1_hpf1_x2R - cab1_hpf_a1n * cab1_hpf1_y1R - cab1_hpf_a2n * cab1_hpf1_y2R;
  cab1_hpf1_x2R = cab1_hpf1_x1R; cab1_hpf1_x1R = tmp; cab1_hpf1_y2R = cab1_hpf1_y1R; cab1_hpf1_y1R = spl1;

  tmp = spl0;
  spl0 = cab1_hpf_b0n * tmp + cab1_hpf_b1n * cab1_hpf2_x1L + cab1_hpf_b2n * cab1_hpf2_x2L - cab1_hpf_a1n * cab1_hpf2_y1L - cab1_hpf_a2n * cab1_hpf2_y2L;
  cab1_hpf2_x2L = cab1_hpf2_x1L; cab1_hpf2_x1L = tmp; cab1_hpf2_y2L = cab1_hpf2_y1L; cab1_hpf2_y1L = spl0;
  tmp = spl1;
  spl1 = cab1_hpf_b0n * tmp + cab1_hpf_b1n * cab1_hpf2_x1R + cab1_hpf_b2n * cab1_hpf2_x2R - cab1_hpf_a1n * cab1_hpf2_y1R - cab1_hpf_a2n * cab1_hpf2_y2R;
  cab1_hpf2_x2R = cab1_hpf2_x1R; cab1_hpf2_x1R = tmp; cab1_hpf2_y2R = cab1_hpf2_y1R; cab1_hpf2_y1R = spl1;

  tmp = spl0;
  spl0 = cab1_hpf_b0n * tmp + cab1_hpf_b1n * cab1_hpf3_x1L + cab1_hpf_b2n * cab1_hpf3_x2L - cab1_hpf_a1n * cab1_hpf3_y1L - cab1_hpf_a2n * cab1_hpf3_y2L;
  cab1_hpf3_x2L = cab1_hpf3_x1L; cab1_hpf3_x1L = tmp; cab1_hpf3_y2L = cab1_hpf3_y1L; cab1_hpf3_y1L = spl0;
  tmp = spl1;
  spl1 = cab1_hpf_b0n * tmp + cab1_hpf_b1n * cab1_hpf3_x1R + cab1_hpf_b2n * cab1_hpf3_x2R - cab1_hpf_a1n * cab1_hpf3_y1R - cab1_hpf_a2n * cab1_hpf3_y2R;
  cab1_hpf3_x2R = cab1_hpf3_x1R; cab1_hpf3_x1R = tmp; cab1_hpf3_y2R = cab1_hpf3_y1R; cab1_hpf3_y1R = spl1;

  tmp = spl0;
  spl0 = cab1_hpf_b0n * tmp + cab1_hpf_b1n * cab1_hpf4_x1L + cab1_hpf_b2n * cab1_hpf4_x2L - cab1_hpf_a1n * cab1_hpf4_y1L - cab1_hpf_a2n * cab1_hpf4_y2L;
  cab1_hpf4_x2L = cab1_hpf4_x1L; cab1_hpf4_x1L = tmp; cab1_hpf4_y2L = cab1_hpf4_y1L; cab1_hpf4_y1L = spl0;
  tmp = spl1;
  spl1 = cab1_hpf_b0n * tmp + cab1_hpf_b1n * cab1_hpf4_x1R + cab1_hpf_b2n * cab1_hpf4_x2R - cab1_hpf_a1n * cab1_hpf4_y1R - cab1_hpf_a2n * cab1_hpf4_y2R;
  cab1_hpf4_x2R = cab1_hpf4_x1R; cab1_hpf4_x1R = tmp; cab1_hpf4_y2R = cab1_hpf4_y1R; cab1_hpf4_y1R = spl1;

  tmp = spl0;
  spl0 = cab1_pk98_b0n * tmp + cab1_pk98_b1n * cab1_pk98_x1L + cab1_pk98_b2n * cab1_pk98_x2L - cab1_pk98_a1n * cab1_pk98_y1L - cab1_pk98_a2n * cab1_pk98_y2L;
