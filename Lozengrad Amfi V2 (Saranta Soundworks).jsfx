hex_w = 2 * pi * 5000 / srate;
hex_cos = cos(hex_w);
hex_sin = sin(hex_w);
hex_alpha = hex_sin / (2 * 0.707);
hex_b0 = (1 + hex_cos) / 2;
hex_b1 = -(1 + hex_cos);
hex_b2 = (1 + hex_cos) / 2;
hex_a0 = 1 + hex_alpha;
hex_a1 = -2 * hex_cos;
hex_a2 = 1 - hex_alpha;
hex_b0n = hex_b0 / hex_a0;
hex_b1n = hex_b1 / hex_a0;
hex_b2n = hex_b2 / hex_a0;
hex_a1n = hex_a1 / hex_a0;
hex_a2n = hex_a2 / hex_a0;

