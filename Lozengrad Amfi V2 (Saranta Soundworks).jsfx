cab3_pk2167_b0 = 1 + cab3_pk2167_alpha * cab3_pk2167_A;
cab3_pk2167_b1 = -2 * cab3_pk2167_cos;
cab3_pk2167_b2 = 1 - cab3_pk2167_alpha * cab3_pk2167_A;
cab3_pk2167_a0 = 1 + cab3_pk2167_alpha / cab3_pk2167_A;
cab3_pk2167_a1 = -2 * cab3_pk2167_cos;
cab3_pk2167_a2 = 1 - cab3_pk2167_alpha / cab3_pk2167_A;
cab3_pk2167_b0n = cab3_pk2167_b0 / cab3_pk2167_a0;
cab3_pk2167_b1n = cab3_pk2167_b1 / cab3_pk2167_a0;
cab3_pk2167_b2n = cab3_pk2167_b2 / cab3_pk2167_a0;
