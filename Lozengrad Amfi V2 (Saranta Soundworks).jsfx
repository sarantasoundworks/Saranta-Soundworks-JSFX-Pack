tmp = spl1;
spl1 = mid_pk850_b0n * tmp + mid_pk850_b1n * mid_pk850_x1R + mid_pk850_b2n * mid_pk850_x2R - mid_pk850_a1n * mid_pk850_y1R - mid_pk850_a2n * mid_pk850_y2R;
mid_pk850_x2R = mid_pk850_x1R; mid_pk850_x1R = tmp; mid_pk850_y2R = mid_pk850_y1R; mid_pk850_y1R = spl1;

