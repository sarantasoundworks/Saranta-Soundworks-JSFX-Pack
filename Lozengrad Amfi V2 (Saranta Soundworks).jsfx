spl1 = res_b0n * tmp + res_b1n * res_x1R + res_b2n * res_x2R - res_a1n * res_y1R - res_a2n * res_y2R;
res_x2R = res_x1R; res_x1R = tmp; res_y2R = res_y1R; res_y1R = spl1;

// --- Mid EQ (shared) ---
tmp = spl0;
spl0 = mid_hpf_b0n * tmp + mid_hpf_b1n * mid_hpf_x1L + mid_hpf_b2n * mid_hpf_x2L - mid_hpf_a1n * mid_hpf_y1L - mid_hpf_a2n * mid_hpf_y2L;
mid_hpf_x2L = mid_hpf_x1L; mid_hpf_x1L = tmp; mid_hpf_y2L = mid_hpf_y1L; mid_hpf_y1L = spl0;
tmp = spl1;
spl1 = mid_hpf_b0n * tmp + mid_hpf_b1n * mid_hpf_x1R + mid_hpf_b2n * mid_hpf_x2R - mid_hpf_a1n * mid_hpf_y1R - mid_hpf_a2n * mid_hpf_y2R;
mid_hpf_x2R = mid_hpf_x1R; mid_hpf_x1R = tmp; mid_hpf_y2R = mid_hpf_y1R; mid_hpf_y1R = spl1;

tmp = spl0;
spl0 = mid_ls120_b0n * tmp + mid_ls120_b1n * mid_ls120_x1L + mid_ls120_b2n * mid_ls120_x2L - mid_ls120_a1n * mid_ls120_y1L - mid_ls120_a2n * mid_ls120_y2L;
mid_ls120_x2L = mid_ls120_x1L; mid_ls120_x1L = tmp; mid_ls120_y2L = mid_ls120_y1L; mid_ls120_y1L = spl0;
tmp = spl1;
spl1 = mid_ls120_b0n * tmp + mid_ls120_b1n * mid_ls120_x1R + mid_ls120_b2n * mid_ls120_x2R - mid_ls120_a1n * mid_ls120_y1R - mid_ls120_a2n * mid_ls120_y2R;
mid_ls120_x2R = mid_ls120_x1R; mid_ls120_x1R = tmp; mid_ls120_y2R = mid_ls120_y1R; mid_ls120_y1R = spl1;

tmp = spl0;
spl0 = mid_pk90_b0n * tmp + mid_pk90_b1n * mid_pk90_x1L + mid_pk90_b2n * mid_pk90_x2L - mid_pk90_a1n * mid_pk90_y1L - mid_pk90_a2n * mid_pk90_y2L;
mid_pk90_x2L = mid_pk90_x1L; mid_pk90_x1L = tmp; mid_pk90_y2L = mid_pk90_y1L; mid_pk90_y1L = spl0;
tmp = spl1;
spl1 = mid_pk90_b0n * tmp + mid_pk90_b1n * mid_pk90_x1R + mid_pk90_b2n * mid_pk90_x2R - mid_pk90_a1n * mid_pk90_y1R - mid_pk90_a2n * mid_pk90_y2R;
mid_pk90_x2R = mid_pk90_x1R; mid_pk90_x1R = tmp; mid_pk90_y2R = mid_pk90_y1R; mid_pk90_y1R = spl1;

tmp = spl0;
spl0 = mid_pk364_b0n * tmp + mid_pk364_b1n * mid_pk364_x1L + mid_pk364_b2n * mid_pk364_x2L - mid_pk364_a1n * mid_pk364_y1L - mid_pk364_a2n * mid_pk364_y2L;
mid_pk364_x2L = mid_pk364_x1L; mid_pk364_x1L = tmp; mid_pk364_y2L = mid_pk364_y1L; mid_pk364_y1L = spl0;
tmp = spl1;
spl1 = mid_pk364_b0n * tmp + mid_pk364_b1n * mid_pk364_x1R + mid_pk364_b2n * mid_pk364_x2R - mid_pk364_a1n * mid_pk364_y1R - mid_pk364_a2n * mid_pk364_y2R;
mid_pk364_x2R = mid_pk364_x1R; mid_pk364_x1R = tmp; mid_pk364_y2R = mid_pk364_y1R; mid_pk364_y1R = spl1;

tmp = spl0;
spl0 = mid_pk850_b0n * tmp + mid_pk850_b1n * mid_pk850_x1L + mid_pk850_b2n * mid_pk850_x2L - mid_pk850_a1n * mid_pk850_y1L - mid_pk850_a2n * mid_pk850_y2L;
