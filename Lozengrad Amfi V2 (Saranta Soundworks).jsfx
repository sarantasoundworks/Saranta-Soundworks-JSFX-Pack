desc:Lozengrad Amfi V2 (Saranta Soundworks)
//author: Saranta Soundworks
//This plugin is made possible with the help of "lyria".

// Noise Gate
slider1:0<0,1,1{Off,On}>Gate Enable
slider2:-40<-40,0,0.1>Gate Threshold (dB)

// Input Gain
slider3:0<-24,24,0.1>Input Gain (dB)

// Amp Mode
slider4:0<0,1,1{Classic,Hard}>Amp Mode

// Amp Section
slider5:0<0,24,0.1>Drive

// Tone Stack
slider6:5<0,10,0.1>Bass
slider7:5<0,10,0.1>Mid
slider8:5<0,10,0.1>Treble

// Power Amp Features
slider9:30<0,100,1>Sag (%)
slider10:50<0,100,1>Presence
slider11:40<0,100,1>Resonance (Depth)

// Master
slider12:0<-24,24,0.1>Master Volume (dB)

// Cab Selection
slider13:0<0,3,1{Off,Cab1,Cab2,Cab3}>Cab Select

// Enhancements
slider14:1<0,2,1{Off,Low,High}>Bright Cap
slider15:30<0,100,1>Transient Enhancer
slider16:15<0,100,1>Harmonic Exciter

in_pin:Input L
in_pin:Input R
out_pin:Output L
out_pin:Output R

