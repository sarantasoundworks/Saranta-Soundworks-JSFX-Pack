mid_pk7400_a2 = 1 - mid_pk7400_alpha / mid_pk7400_A;
mid_pk7400_b0n = mid_pk7400_b0 / mid_pk7400_a0;
mid_pk7400_b1n = mid_pk7400_b1 / mid_pk7400_a0;
mid_pk7400_b2n = mid_pk7400_b2 / mid_pk7400_a0;
mid_pk7400_a1n = mid_pk7400_a1 / mid_pk7400_a0;
mid_pk7400_a2n = mid_pk7400_a2 / mid_pk7400_a0;



@sample

// V3 Noise Gate - lookahead + hysteresis + downward expander
gate_enable ? (
  // Write current audio to lookahead delay buffer
  delayL[lookahead_wp] = spl0;
  delayR[lookahead_wp] = spl1;
  
  // Envelope detection: 70% peak (instant attack, 50ms release) + 30% RMS
  abs_in = max(abs(spl0), abs(spl1));
  abs_in > gate_env ? gate_env = abs_in : gate_env = gate_env * (1 - gate_env_release) + abs_in * gate_env_release;
  gate_rms = 0.001 * abs_in * abs_in + 0.999 * gate_rms;
  env_combined = 0.7 * gate_env + 0.3 * sqrt(gate_rms);
  
  // Hysteresis state machine with dynamic hold
  gate_state == 1 ? (
    env_combined < gate_close_thresh ? (
      gate_state = 0;
      gate_hold_rem = floor(srate * (0.02 + 0.06 * min(1, gate_env / gate_open_thresh)));
    );
  ) : (
    env_combined > gate_open_thresh ? (
      gate_state = 1;
    ) : (
      gate_hold_rem > 0 ? gate_hold_rem -= 1;
    );
  );
  
  // Downward expander target gain
  gate_state == 1 ? (
    gate_target = 1;
  ) : (
    gate_hold_rem > 0 ? (
      gate_target = gate_gain;
    ) : (
      env_combined > 0.00001 ? (
        env_dB = 20 * log10(env_combined);
        thresh_dB = 20 * log10(gate_open_thresh);
        db_below = max(0, thresh_dB - env_dB);
        reduction_dB = db_below * (gate_ratio - 1);
        gate_target = 10 ^ (-reduction_dB / 20);
        gate_target < gate_min_gain ? gate_target = gate_min_gain;
      ) : gate_target = gate_min_gain;
    );
  );
  
  // Smooth gain transitions
  gate_target > gate_gain ? (
    gate_gain += (gate_target - gate_gain) * gate_gain_attack;
  ) : (
    gate_gain += (gate_target - gate_gain) * gate_gain_release;
  );
  gate_gain < gate_min_gain ? gate_gain = gate_min_gain;
  
  // Lookahead: read delayed audio and apply gain
  lookahead_rp = lookahead_wp - gate_lookahead;
  lookahead_rp < 0 ? lookahead_rp += max_lookahead;
  spl0 = delayL[lookahead_rp] * gate_gain;
  spl1 = delayR[lookahead_rp] * gate_gain;
  
  // Advance write pointer
  lookahead_wp += 1;
  lookahead_wp >= max_lookahead ? lookahead_wp = 0;
);

// Input Gain
spl0 *= input_gain;
spl1 *= input_gain;

// Pre-EQ
tmp = spl0;
spl0 = hpf_b0n * tmp + hpf_b1n * hpf1_x1L + hpf_b2n * hpf1_x2L - hpf_a1n * hpf1_y1L - hpf_a2n * hpf1_y2L;
hpf1_x2L = hpf1_x1L; hpf1_x1L = tmp; hpf1_y2L = hpf1_y1L; hpf1_y1L = spl0;
tmp = spl1;
spl1 = hpf_b0n * tmp + hpf_b1n * hpf1_x1R + hpf_b2n * hpf1_x2R - hpf_a1n * hpf1_y1R - hpf_a2n * hpf1_y2R;
hpf1_x2R = hpf1_x1R; hpf1_x1R = tmp; hpf1_y2R = hpf1_y1R; hpf1_y1R = spl1;

tmp = spl0;
spl0 = hpf_b0n * tmp + hpf_b1n * hpf2_x1L + hpf_b2n * hpf2_x2L - hpf_a1n * hpf2_y1L - hpf_a2n * hpf2_y2L;
hpf2_x2L = hpf2_x1L; hpf2_x1L = tmp; hpf2_y2L = hpf2_y1L; hpf2_y1L = spl0;
tmp = spl1;
spl1 = hpf_b0n * tmp + hpf_b1n * hpf2_x1R + hpf_b2n * hpf2_x2R - hpf_a1n * hpf2_y1R - hpf_a2n * hpf2_y2R;
hpf2_x2R = hpf2_x1R; hpf2_x1R = tmp; hpf2_y2R = hpf2_y1R; hpf2_y1R = spl1;

tmp = spl0;
spl0 = hpf_b0n * tmp + hpf_b1n * hpf3_x1L + hpf_b2n * hpf3_x2L - hpf_a1n * hpf3_y1L - hpf_a2n * hpf3_y2L;
hpf3_x2L = hpf3_x1L; hpf3_x1L = tmp; hpf3_y2L = hpf3_y1L; hpf3_y1L = spl0;
tmp = spl1;
spl1 = hpf_b0n * tmp + hpf_b1n * hpf3_x1R + hpf_b2n * hpf3_x2R - hpf_a1n * hpf3_y1R - hpf_a2n * hpf3_y2R;
hpf3_x2R = hpf3_x1R; hpf3_x1R = tmp; hpf3_y2R = hpf3_y1R; hpf3_y1R = spl1;

tmp = spl0;
spl0 = hpf_b0n * tmp + hpf_b1n * hpf4_x1L + hpf_b2n * hpf4_x2L - hpf_a1n * hpf4_y1L - hpf_a2n * hpf4_y2L;
hpf4_x2L = hpf4_x1L; hpf4_x1L = tmp; hpf4_y2L = hpf4_y1L; hpf4_y1L = spl0;
tmp = spl1;
spl1 = hpf_b0n * tmp + hpf_b1n * hpf4_x1R + hpf_b2n * hpf4_x2R - hpf_a1n * hpf4_y1R - hpf_a2n * hpf4_y2R;
hpf4_x2R = hpf4_x1R; hpf4_x1R = tmp; hpf4_y2R = hpf4_y1R; hpf4_y1R = spl1;

tmp = spl0;
spl0 = pk95_b0n * tmp + pk95_b1n * pk95_x1L + pk95_b2n * pk95_x2L - pk95_a1n * pk95_y1L - pk95_a2n * pk95_y2L;
pk95_x2L = pk95_x1L; pk95_x1L = tmp; pk95_y2L = pk95_y1L; pk95_y1L = spl0;
tmp = spl1;
spl1 = pk95_b0n * tmp + pk95_b1n * pk95_x1R + pk95_b2n * pk95_x2R - pk95_a1n * pk95_y1R - pk95_a2n * pk95_y2R;
pk95_x2R = pk95_x1R; pk95_x1R = tmp; pk95_y2R = pk95_y1R; pk95_y1R = spl1;

tmp = spl0;
spl0 = sh108_b0n * tmp + sh108_b1n * sh108_x1L + sh108_b2n * sh108_x2L - sh108_a1n * sh108_y1L - sh108_a2n * sh108_y2L;
sh108_x2L = sh108_x1L; sh108_x1L = tmp; sh108_y2L = sh108_y1L; sh108_y1L = spl0;
tmp = spl1;
spl1 = sh108_b0n * tmp + sh108_b1n * sh108_x1R + sh108_b2n * sh108_x2R - sh108_a1n * sh108_y1R - sh108_a2n * sh108_y2R;
sh108_x2R = sh108_x1R; sh108_x1R = tmp; sh108_y2R = sh108_y1R; sh108_y1R = spl1;

tmp = spl0;
spl0 = pk291_b0n * tmp + pk291_b1n * pk291_x1L + pk291_b2n * pk291_x2L - pk291_a1n * pk291_y1L - pk291_a2n * pk291_y2L;
pk291_x2L = pk291_x1L; pk291_x1L = tmp; pk291_y2L = pk291_y1L; pk291_y1L = spl0;
tmp = spl1;
spl1 = pk291_b0n * tmp + pk291_b1n * pk291_x1R + pk291_b2n * pk291_x2R - pk291_a1n * pk291_y1R - pk291_a2n * pk291_y2R;
pk291_x2R = pk291_x1R; pk291_x1R = tmp; pk291_y2R = pk291_y1R; pk291_y1R = spl1;

tmp = spl0;
spl0 = pk120_b0n * tmp + pk120_b1n * pk120_x1L + pk120_b2n * pk120_x2L - pk120_a1n * pk120_y1L - pk120_a2n * pk120_y2L;
pk120_x2L = pk120_x1L; pk120_x1L = tmp; pk120_y2L = pk120_y1L; pk120_y1L = spl0;
tmp = spl1;
spl1 = pk120_b0n * tmp + pk120_b1n * pk120_x1R + pk120_b2n * pk120_x2R - pk120_a1n * pk120_y1R - pk120_a2n * pk120_y2R;
pk120_x2R = pk120_x1R; pk120_x1R = tmp; pk120_y2R = pk120_y1R; pk120_y1R = spl1;

tmp = spl0;
spl0 = pk2k_b0n * tmp + pk2k_b1n * pk2k_x1L + pk2k_b2n * pk2k_x2L - pk2k_a1n * pk2k_y1L - pk2k_a2n * pk2k_y2L;
pk2k_x2L = pk2k_x1L; pk2k_x1L = tmp; pk2k_y2L = pk2k_y1L; pk2k_y1L = spl0;
tmp = spl1;
spl1 = pk2k_b0n * tmp + pk2k_b1n * pk2k_x1R + pk2k_b2n * pk2k_x2R - pk2k_a1n * pk2k_y1R - pk2k_a2n * pk2k_y2R;
pk2k_x2R = pk2k_x1R; pk2k_x1R = tmp; pk2k_y2R = pk2k_y1R; pk2k_y1R = spl1;

tmp = spl0;
spl0 = lpf_b0n * tmp + lpf_b1n * lpf_x1L + lpf_b2n * lpf_x2L - lpf_a1n * lpf_y1L - lpf_a2n * lpf_y2L;
lpf_x2L = lpf_x1L; lpf_x1L = tmp; lpf_y2L = lpf_y1L; lpf_y1L = spl0;
tmp = spl1;
spl1 = lpf_b0n * tmp + lpf_b1n * lpf_x1R + lpf_b2n * lpf_x2R - lpf_a1n * lpf_y1R - lpf_a2n * lpf_y2R;
lpf_x2R = lpf_x1R; lpf_x1R = tmp; lpf_y2R = lpf_y1R; lpf_y1R = spl1;

// --- Tube Stage 1 (Classic only) ---
amp_mode == 0 ? (
  spl0 = (spl0 * drive * 0.6) / (1 + abs(spl0 * drive * 0.6));
  spl1 = (spl1 * drive * 0.6) / (1 + abs(spl1 * drive * 0.6));
  spl0 *= 0.9;
  spl1 *= 0.9;
);

// --- Bright Cap (shared) ---
bright_cap > 0 ? (
  bc_y1L = spl0 + bc_cutoff * (bc_y1L - spl0);
  bc_y1R = spl1 + bc_cutoff * (bc_y1R - spl1);
  spl0 = bc_y1L;
  spl1 = bc_y1R;
);

// --- Distortion Core Switch ---
amp_mode == 0 ? (
  // Tube Stage 2
  spl0 = (spl0 * drive * 0.8) / (1 + abs(spl0 * drive * 0.8)) - 0.06 * (spl0 * drive * 0.4) / (1 + abs(spl0 * drive * 0.4));
  spl1 = (spl1 * drive * 0.8) / (1 + abs(spl1 * drive * 0.8)) - 0.06 * (spl1 * drive * 0.4) / (1 + abs(spl1 * drive * 0.4));
  spl0 *= 0.85;
  spl1 *= 0.85;

  // Cold Clipper
  spl0 = spl0 + 0.1;
  spl1 = spl1 + 0.1;
  spl0 >= 0 ? spl0 = (spl0 * 0.7) / (1 + abs(spl0 * 0.7)) : spl0 = (spl0 * 1.2) / (1 + abs(spl0 * 1.2));
  spl1 >= 0 ? spl1 = (spl1 * 0.7) / (1 + abs(spl1 * 0.7)) : spl1 = (spl1 * 1.2) / (1 + abs(spl1 * 1.2));
  spl0 = spl0 - 0.1;
  spl1 = spl1 - 0.1;

  spl0 *= 0.7;
  spl1 *= 0.7;
) : (
  // Hard clipper chain
  spl0 *= 3 * drive;
  spl1 *= 3 * drive;

  spl0 > 1 ? spl0 = 1; spl0 < -1 ? spl0 = -1;
  spl1 > 1 ? spl1 = 1; spl1 < -1 ? spl1 = -1;
  spl0 *= 2.5; spl1 *= 2.5;

  spl0 > 1 ? spl0 = 1; spl0 < -1 ? spl0 = -1;
  spl1 > 1 ? spl1 = 1; spl1 < -1 ? spl1 = -1;
  spl0 *= 2; spl1 *= 2;

  spl0 > 1 ? spl0 = 1; spl0 < -1 ? spl0 = -1;
  spl1 > 1 ? spl1 = 1; spl1 < -1 ? spl1 = -1;

  // Auto gain
  auto_gain_env = (abs(spl0) + abs(spl1)) * 0.5 * 0.1 + auto_gain_env * 0.9;
  auto_gain_env > 0.001 ? auto_gain = 1 / (auto_gain_env + 0.1) : auto_gain = 1;
  spl0 *= auto_gain * 0.5;
  spl1 *= auto_gain * 0.5;
);

// --- Tone Stack (shared) ---
tmp = spl0;
spl0 = ts_bass_b0n * tmp + ts_bass_b1n * ts_bass_x1L + ts_bass_b2n * ts_bass_x2L - ts_bass_a1n * ts_bass_y1L - ts_bass_a2n * ts_bass_y2L;
ts_bass_x2L = ts_bass_x1L; ts_bass_x1L = tmp; ts_bass_y2L = ts_bass_y1L; ts_bass_y1L = spl0;
tmp = spl1;
spl1 = ts_bass_b0n * tmp + ts_bass_b1n * ts_bass_x1R + ts_bass_b2n * ts_bass_x2R - ts_bass_a1n * ts_bass_y1R - ts_bass_a2n * ts_bass_y2R;
ts_bass_x2R = ts_bass_x1R; ts_bass_x1R = tmp; ts_bass_y2R = ts_bass_y1R; ts_bass_y1R = spl1;

tmp = spl0;
spl0 = ts_mid_b0n * tmp + ts_mid_b1n * ts_mid_x1L + ts_mid_b2n * ts_mid_x2L - ts_mid_a1n * ts_mid_y1L - ts_mid_a2n * ts_mid_y2L;
ts_mid_x2L = ts_mid_x1L; ts_mid_x1L = tmp; ts_mid_y2L = ts_mid_y1L; ts_mid_y1L = spl0;
tmp = spl1;
spl1 = ts_mid_b0n * tmp + ts_mid_b1n * ts_mid_x1R + ts_mid_b2n * ts_mid_x2R - ts_mid_a1n * ts_mid_y1R - ts_mid_a2n * ts_mid_y2R;
ts_mid_x2R = ts_mid_x1R; ts_mid_x1R = tmp; ts_mid_y2R = ts_mid_y1R; ts_mid_y1R = spl1;

tmp = spl0;
spl0 = ts_treb_b0n * tmp + ts_treb_b1n * ts_treb_x1L + ts_treb_b2n * ts_treb_x2L - ts_treb_a1n * ts_treb_y1L - ts_treb_a2n * ts_treb_y2L;
ts_treb_x2L = ts_treb_x1L; ts_treb_x1L = tmp; ts_treb_y2L = ts_treb_y1L; ts_treb_y1L = spl0;
tmp = spl1;
spl1 = ts_treb_b0n * tmp + ts_treb_b1n * ts_treb_x1R + ts_treb_b2n * ts_treb_x2R - ts_treb_a1n * ts_treb_y1R - ts_treb_a2n * ts_treb_y2R;
ts_treb_x2R = ts_treb_x1R; ts_treb_x1R = tmp; ts_treb_y2R = ts_treb_y1R; ts_treb_y1R = spl1;

// --- Tube Stage 3 (Classic only) ---
amp_mode == 0 ? (
  spl0 = (spl0 * 0.8) / (1 + abs(spl0 * 0.8)) - 0.04 * (spl0 * 0.4) / (1 + abs(spl0 * 0.4));
  spl1 = (spl1 * 0.8) / (1 + abs(spl1 * 0.8)) - 0.04 * (spl1 * 0.4) / (1 + abs(spl1 * 0.4));
  spl0 *= 0.95;
  spl1 *= 0.95;
);

// --- Presence (shared) ---
tmp = spl0;
spl0 = pres_b0n * tmp + pres_b1n * pres_x1L + pres_b2n * pres_x2L - pres_a1n * pres_y1L - pres_a2n * pres_y2L;
pres_x2L = pres_x1L; pres_x1L = tmp; pres_y2L = pres_y1L; pres_y1L = spl0;
tmp = spl1;
spl1 = pres_b0n * tmp + pres_b1n * pres_x1R + pres_b2n * pres_x2R - pres_a1n * pres_y1R - pres_a2n * pres_y2R;
pres_x2R = pres_x1R; pres_x1R = tmp; pres_y2R = pres_y1R; pres_y1R = spl1;

// --- Power Amp (Classic only) ---
amp_mode == 0 ? (
  spl0 = (spl0 * 1.2) / (1 + abs(spl0 * 1.2));
  spl1 = (spl1 * 1.2) / (1 + abs(spl1 * 1.2));
);

// --- Sag (shared) ---
sag_env = max(abs(spl0), abs(spl1)) * sag_attack + sag_env * (1 - sag_attack);
sag_target = 1 - (sag_env * sag_amount * 2);
sag_target < 0.3 ? sag_target = 0.3;
sag_gain = sag_gain * (1 - sag_release) + sag_target * sag_release;
spl0 *= sag_gain;
spl1 *= sag_gain;

// --- Resonance (shared) ---
tmp = spl0;
spl0 = res_b0n * tmp + res_b1n * res_x1L + res_b2n * res_x2L - res_a1n * res_y1L - res_a2n * res_y2L;
res_x2L = res_x1L; res_x1L = tmp; res_y2L = res_y1L; res_y1L = spl0;
