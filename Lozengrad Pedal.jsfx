hd_sh_x1_R = 0; hd_sh_x2_R = 0; hd_sh_y1_R = 0; hd_sh_y2_R = 0;
hd_sh_a0 = 1; hd_sh_a1 = 0; hd_sh_a2 = 0; hd_sh_b0 = 1; hd_sh_b1 = 0; hd_sh_b2 = 0;

// MT-2 state (HPF 35Hz + Gyrator1 250Hz + Gyrator2 1kHz)
