f33_pk_a0 = 1; f33_pk_a1 = 0; f33_pk_a2 = 0; f33_pk_b1 = 0; f33_pk_b2 = 0;

// Horizon Devices state (HPF + Peaking + High-Shelf)
hd_hpf_x1_L = 0; hd_hpf_y1_L = 0;
hd_hpf_x1_R = 0; hd_hpf_y1_R = 0;
hd_hpf_a0 = 0; hd_hpf_a1 = 0; hd_hpf_b1 = 0;

hd_pk_x1_L = 0; hd_pk_x2_L = 0; hd_pk_y1_L = 0; hd_pk_y2_L = 0;
hd_pk_x1_R = 0; hd_pk_x2_R = 0; hd_pk_y1_R = 0; hd_pk_y2_R = 0;
