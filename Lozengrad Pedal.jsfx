aa_x1_R = 0; aa_x2_R = 0; aa_y1_R = 0; aa_y2_R = 0;
aa_a0 = 0; aa_a1 = 0; aa_a2 = 0;
aa_b1 = 0; aa_b2 = 0;

ts1_x1_L = 0; ts1_x2_L = 0; ts1_y1_L = 0; ts1_y2_L = 0;
ts1_x1_R = 0; ts1_x2_R = 0; ts1_y1_R = 0; ts1_y2_R = 0;
