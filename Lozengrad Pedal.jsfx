desc:Lozengrad Pedal
//tags: distortion guitar
//author: DSP Modelleme

// ============================================================
// Boss DS-2 Turbo Distortion - JSFX Simulation
// Teknik Rapor Spesifikasyonlarına Uygun
//
// Sinyal Zinciri:
//   Input Buffer -> Pre-EQ HPF (80Hz) -> Soft Clip (D14/D15)
//   -> DC Blocker -> Turbo Stage (Q23 + BP 900Hz + Notch 2500Hz)
//   -> Hard Clip (D11/D12) -> Anti-Alias LPF
//   -> Tone Stack (Peaking + Low-Shelf) -> Output Level
// ============================================================

slider1:5<0,100,1>Gain
slider2:0<-1,1,0.01>Tone
slider3:50<0,100,1>Level
slider4:0<0,6,1{Turbo I,Turbo II,DS-1,Green TS,Fortin 33,Horizon,MT-2}>Pedal Mode
slider5:1<0,2,1{Off,4x,8x}>Oversampling
slider6:0<-15,15,0.1>Low
slider7:1000<200,5000,1>Mid Freq
slider8:0<-15,15,0.1>Mid Gain
slider9:0<-15,15,0.1>High

@init

gain_lin = 1.0;
level_lin = 1.0;
tone_pos = 0;
turbo_mode = 0;
os_mode = 1;

dc_alpha = 0.997;
dc_in_x1 = 0; dc_in_y1 = 0;
